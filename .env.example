# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL="mysql://:`DB_PASSWORD`@`DB_HOST`:`DB_PORT`/`DB_NAME`"
# Replace na lang yung may mga backticks.
# Example: "mysql://root:paszw0rd@localhost:3306/qcu_msc_central_portal"

# Better Auth Configuration
BETTER_AUTH_SECRET="0fdf8f33cee214997ff9fe5d3179d0a90883c7fed0958a250328cdf52a015a80"
BETTER_AUTH_URL="http://localhost:5000"

# OCR & Image Storage
OCR_MAX_FAILURES=3

# OAuth — Google (optional, leave empty to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth — GitHub (optional, leave empty to disable)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Frontend URL (for CORS and CSRF protection)
FRONTEND_URL="http://localhost:5173"
ADMIN_FRONTEND_URL="http://localhost:8081"

# Azure Storage Configuration
AZURE_STORAGE_ACCOUNT_NAME=""

# Azure Authentication (Service Principal)
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_TENANT_ID=""

# Email Provider (RESEND for production, SMTP for development)
# EMAIL_PROVIDER=RESEND
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL=no-reply@anonimi.cloud

# SMTP Config (development — uncomment and fill to use SMTP)
EMAIL_PROVIDER=SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-email-password-or-app-password" # Get yours from https://myaccount.google.com/apppasswords
SMTP_FROM_NAME=Microsoft Student Community
SMTP_FROM_EMAIL="your-email@gmail.com"