# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL="mysql://:`DB_PASSWORD`@`DB_HOST`:`DB_PORT`/`DB_NAME`"
# Replace na lang yung may mga backticks.
# Example: "mysql://root:paszw0rd@localhost:3306/qcu_msc_central_portal"

# JWT Secrets
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Better Auth Configuration
BETTER_AUTH_SECRET="better-auth-secret-change-in-production"
BETTER_AUTH_URL="http://localhost:5000"
